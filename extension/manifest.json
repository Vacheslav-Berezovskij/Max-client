{
  "manifest_version": 3,
  "name": "MAXSEC Privacy Layer",
  "version": "0.1.0",
  "description": "Optional in-chat encryption layer for MAX web client without backend dependencies.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://max.ru/*",
    "https://*.max.ru/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://max.ru/*",
        "https://*.max.ru/*"
      ],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dist/injected.js"],
      "matches": [
        "https://max.ru/*",
        "https://*.max.ru/*"
      ]
    }
  ],
  "options_page": "options/options.html"
}
